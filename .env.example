# Copy to .env. Never commit the resulting .env.
#
# Personal credentials used by interactive examples. They are read only
# inside example/test scripts; the library itself never reads .env.

# OACX (kakao/naver) authentication uses the holder's name/phone/birthday.
HOMETAX_NAME=
HOMETAX_PHONE=
HOMETAX_BIRTH=

# ID/PW authentication uses the HomeTax login id, password, and the
# resident-registration number used as the second-step (앞 7자리 또는 13자리).
HOMETAX_USER_ID=
HOMETAX_PASSWORD=
HOMETAX_RRN=
